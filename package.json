{
  "name": "packages-for-work",
  "version": "1.0.0",
  "description": "Monorepo to temporarily host some packages for work until we set up our new Org",
  "type": "module",
  "scripts": {
    "build": "npx nx run-many --target=build --exclude=@mikesprague/package-starter,@mikesprague/ct-azure",
    "clean": "npx nx run-many --target=clean --exclude=@mikesprague/package-starter,@mikesprague/ct-azure",
    "format": "npx nx run-many --target=format --exclude=@mikesprague/package-starter,@mikesprague/ct-azure",
    "format:check": "npx nx run-many --target=format:check --exclude=@mikesprague/package-starter,@mikesprague/ct-azure",
    "lint": "npm run oxlint && npm run typecheck",
    "oxlint": "npx nx run-many --target=lint --exclude=@mikesprague/package-starter,@mikesprague/ct-azure",
    "release": "npx nx release",
    "release:dry-run": "npm run release -- --dry-run",
    "release:version": "npx nx release version",
    "release:changelog": "npx nx release changelog",
    "release:publish": "npx nx release publish",
    "test": "npm run lint && npm run vitest:coverage -- --silent",
    "typecheck": "npx nx run-many --target=typecheck --exclude=@mikesprague/package-starter,@mikesprague/ct-azure",
    "vitest": "npx vitest run",
    "vitest:watch": "npx vitest run --watch",
    "vitest:coverage": "npx vitest run --coverage"
  },
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.17.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikesprague/packages-for-work.git"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikesprague/packages-for-work/issues"
  },
  "homepage": "https://github.com/mikesprague/packages-for-work#readme",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@nx/js": "23.0.1",
    "@nx/vite": "23.0.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.43",
    "@swc/helpers": "0.5.23",
    "@types/node": "26.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "cz-git": "1.13.1",
    "documentation": "14.0.3",
    "nx": "23.0.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "rimraf": "6.1.3",
    "tsdown": "0.22.3",
    "typedoc": "^0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "axios": "1.18.0",
    "brace-expansion": "^5.0.6",
    "follow-redirects": "^1.16.0",
    "form-data": "^4.0.6",
    "glob": "^13.0.6",
    "minimatch": "^10.2.5",
    "tmp": "^0.2.7",
    "uuid": "^14.0.0",
    "vue-template-compiler": "^3.0.0",
    "yaml": "^2.9.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.3.0",
    "npm": "11.17.0"
  },
  "allowScripts": {
    "@swc/core@1.15.41": true,
    "nx@23.0.0": true
  }
}
